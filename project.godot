; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="snowman_remastered"
run/main_scene="uid://c7fqxuuss4qoc"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://main_/icon.svg"

[autoload]

PlayerData="*uid://dc5w57ou10hoa"
LayerNames="*uid://onwu1am46l7t"

[editor]

movie_writer/movie_file="E:/snowman/test_.avi"
version_control/plugin_name="godot-git-plugin"

[editor_plugins]

enabled=PackedStringArray("res://addons/layer_namer/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "gray",
"res://background and foregrounds/": "green",
"res://enemies/": "red",
"res://misc_scenes/": "gray",
"res://overworld/": "green",
"res://player/": "blue",
"res://projectiles/": "orange",
"res://shaders/": "green",
"res://singletons/": "orange"
}

